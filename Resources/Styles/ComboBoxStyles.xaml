<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- #region ComboBox Styles -->

    <Style TargetType="ComboBox">
        <Setter Property="Height" Value="34"/>
        <Setter Property="Margin" Value="{StaticResource MarginSize}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>

                        <!--Border-->
                        <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}">

                            <Grid>
                                <!--Selected Content-->
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />

                                <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Right"
                                          Width="35">

                                    <Path Data="M 0 0 L 4 4 L 8 0"
                                      Stroke="{StaticResource PrimaryBrush}"
                                      StrokeThickness="2"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                                </ToggleButton>
                            </Grid>
                        </Border>

                        <!--Popup-->
                        <Popup x:Name="Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade">

                            <Border Background="White"
                                BorderBrush="{StaticResource PrimaryBrush}"
                                BorderThickness="1"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                Padding="10">

                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>

                            </Border>
                        </Popup>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <!--Hover-->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="{StaticResource PrimaryHoverBrush}"/>
                        </Trigger>

                        <!--Focus-->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>

                        <!--Open state-->
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox Item Styles -->
    <Style
    TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="{StaticResource PaddingSizeMedium}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border"
                                Property="Background"
                                Value="{StaticResource PrimaryDisabledBrush}"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border"
                                Property="Background"
                                Value="#E0EFFF"/>
                            <Setter Property="Foreground"
                                Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--#endregion-->

</ResourceDictionary>