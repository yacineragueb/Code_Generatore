<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- #region Label Styles -->

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLarge}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
    </Style>

    <!-- #endregion -->

    <!-- #region TextBlock Styles -->

    <Style x:Key="DescriptionText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Foreground" Value="Gray"/>
    </Style>

    <Style x:Key="InfoTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="InfoValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
        <Setter Property="Foreground" Value="Gray"/>
    </Style>

    <Style x:Key="ErrorMessageStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}"/>
        <Setter Property="Margin" Value="{StaticResource MarginSize}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Foreground" Value="Red"/>
    </Style>

    <!-- #endregion -->

</ResourceDictionary>