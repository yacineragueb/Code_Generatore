<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- #region Input Controls Style -->

    <Style x:Key="InputStyle" TargetType="Control">
        <Setter Property="Padding" Value="{StaticResource PaddingSizeSmall}"/>
        <Setter Property="Margin" Value="{StaticResource MarginSize}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLarge}"/>
        <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
    </Style>

    <!--#endregion-->

    <!-- #region TextBox Styles -->

    <Style TargetType="TextBox"
       BasedOn="{StaticResource InputStyle}" />

    <!-- #endregion -->

    <!-- #region PasswordBox Styles -->

    <Style TargetType="PasswordBox"
       BasedOn="{StaticResource InputStyle}" >
        <Setter Property="PasswordChar" Value="•" />
    </Style>

    <!-- #endregion -->

</ResourceDictionary>