<Window x:Class="Code_Generatore.CodeGeneratoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Code_Generatore"
        xmlns:userControl="clr-namespace:Code_Generatore.UserControls"
        xmlns:conv="clr-namespace:Code_Generatore.Converters"
        mc:Ignorable="d"
        Title="Code generatore" MinHeight="500" MinWidth="1000"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed" Height="700">

    <Window.Resources>
        <conv:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"  /> <!-- Left Side -->
            <RowDefinition Height="Auto" /> <!-- Bottom Side -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"  /> <!-- Left Side -->
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--region Right Side -->
        <Grid Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="{StaticResource MarginSize}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Top Panel -->
            <Border Grid.Row="0"
                    Grid.ColumnSpan="3"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource PrimaryBrush}"
                            Padding="{StaticResource PaddingSizeSmall}">
                        <TextBlock Text="General information"
                                   Foreground="White"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="{StaticResource MarginSize}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Server -->
                        <userControl:InfoItemControl Grid.Column="0"
                            Title="Server Name :" Value="{Binding Session.ServerName}" />

                        <!-- Username -->
                        <userControl:InfoItemControl Grid.Column="1"
                            Title="Username :" Value="{Binding Session.UserName}" />

                        <!-- Status -->
                        <userControl:InfoItemControl Grid.Column="2"
                            Title="Status :" Value="{Binding Session.ConnectionStatus}" />

                        <!-- Database -->
                        <userControl:InfoItemControl Grid.Column="3"
                            Title="Database Name :" Value="{Binding SelectedDatabaseDisplay}" />
                    </Grid>
                </Grid>
            </Border>
            
            <!-- Middle Panel -->
            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="1"
                    Margin="0,5,5,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="{StaticResource PrimaryBrush}"
                            Padding="{StaticResource PaddingSizeSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Preview Window"
                                Foreground="White" VerticalAlignment="Center"/>

                            <Button Grid.Column="1"
                                    Command="{Binding CopyPreviewCommand}"
                                    IsEnabled="{Binding HasPreviewCode}"
                                    Background="White"
                                    Padding="8,3"
                                    Cursor="Hand"
                                    BorderBrush="{StaticResource PrimaryBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Resources/Images/Copy.png"
                                           Width="18"
                                           Height="24"
                                           Margin="0,0,6,0"/>
                                    <TextBlock Text="Copy"
                                               VerticalAlignment="Center"
                                               FontWeight="Medium"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               FontFamily="{StaticResource PoppinsFont}"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        
                    </Border>

                    <!-- Body -->
                    <Grid Grid.Row="1">
                        <TextBox  IsReadOnly="True"
                                  AcceptsReturn="True"
                                  AcceptsTab="True"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  FontFamily="Consolas"
                                  TextWrapping="NoWrap"
                                  Margin="0"
                                  BorderThickness="0"
                                  Text="{Binding PreviewCode}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Left Panel -->
            <Border Grid.Row="1"
                    Grid.Column="2"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="1"
                    Margin="0,5,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="{StaticResource PrimaryBrush}"
                            Padding="{StaticResource PaddingSizeSmall}">
                        <TextBlock Text="Operations"
                            Foreground="White"/>
                    </Border>

                    <!-- Operations -->
                    <StackPanel Grid.Row="1"
                                Margin="{StaticResource MarginSize}"
                                Orientation="Vertical">
                        
                        <CheckBox Margin="{StaticResource MarginSize}" 
                                  Content="Select all" 
                                  IsEnabled="{Binding CanSelectAllOperations}"
                                  IsChecked="{Binding AreAllOperationsChecked}"/>

                        <!-- Insert -->
                        <Grid Margin="{StaticResource MarginSize}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      x:Name="InsertCheckBox"
                                      IsChecked="{Binding InsertSelected}"
                                      IsEnabled="{Binding AreOperationsEnabled}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding InsertFunctionName, UpdateSourceTrigger=LostFocus}"
                                     Padding="8,4"
                                     HorizontalAlignment="Stretch"
                                     IsEnabled="{Binding IsChecked, ElementName=InsertCheckBox}"/>
                        </Grid>

                        <!-- Update -->
                        <Grid Margin="{StaticResource MarginSize}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      x:Name="UpdateCheckBox"
                                      IsChecked="{Binding UpdateSelected}"
                                      IsEnabled="{Binding AreOperationsEnabled}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding UpdateFunctionName, UpdateSourceTrigger=LostFocus}"
                                     Padding="8,4"
                                     HorizontalAlignment="Stretch"
                                     IsEnabled="{Binding IsChecked, ElementName=UpdateCheckBox}"/>
                        </Grid>

                        <!-- Delete -->
                        <Grid Margin="{StaticResource MarginSize}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      x:Name="DeleteCheckBox"
                                      IsChecked="{Binding DeleteSelected}"
                                      IsEnabled="{Binding AreOperationsEnabled}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding DeleteFunctionName, UpdateSourceTrigger=LostFocus}"
                                     Padding="8,4"
                                     HorizontalAlignment="Stretch"
                                     IsEnabled="{Binding IsChecked, ElementName=DeleteCheckBox}"/>
                        </Grid>

                        <!-- GetById -->
                        <Grid Margin="{StaticResource MarginSize}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      x:Name="GetByIdCheckBox"
                                      IsChecked="{Binding GetByIdSelected}"
                                      IsEnabled="{Binding AreOperationsEnabled}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding GetByIdFunctionName, UpdateSourceTrigger=LostFocus}"
                                     Padding="8,4"
                                     HorizontalAlignment="Stretch"
                                     IsEnabled="{Binding IsChecked, ElementName=GetByIdCheckBox}"/>
                        </Grid>

                        <!-- GetAll -->
                        <Grid Margin="{StaticResource MarginSize}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      x:Name="GetAllCheckBox"
                                      IsChecked="{Binding GetAllSelected}"
                                      IsEnabled="{Binding AreOperationsEnabled}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding GetAllFunctionName, UpdateSourceTrigger=LostFocus}"
                                     Padding="8,4"
                                     HorizontalAlignment="Stretch"
                                     IsEnabled="{Binding IsChecked, ElementName=GetAllCheckBox}"/>
                        </Grid>
                    </StackPanel>

                    <Separator Grid.Row="2"/>

                    <TextBlock Grid.Row="3" Style="{StaticResource DescriptionText}" 
                               TextWrapping="Wrap"
                               Margin="{StaticResource MarginSize}">
                            <Bold>Note:</Bold> Use the <Bold>Preview Window</Bold> to generate and inspect code for a specific table. To generate all files and create the complete project, click the <Bold>Generate</Bold> button below.
                    </TextBlock>

                    <Button x:Name="GenerateBtn" Grid.Row="4"
                            Style="{StaticResource PrimaryBtn}"
                            Content="Generate"
                            IsEnabled="{Binding CanGenerate}"
                            Command="{Binding GenerateCommand}"/>
                </Grid>
            </Border>
        </Grid>

        <!--#endregion-->
        
        <!--#region Left Side-->

        <Grid Background="{StaticResource PrimaryBrush}" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Database name selector -->
            <StackPanel Grid.Row="0" >
                <Label Content="Choose your database:" Foreground="White" />
                <ComboBox x:Name="DatabasesComboBox"
                          ItemsSource="{Binding DatabasesList}" 
                          SelectedItem="{Binding SelectedDatabase, Mode=TwoWay}" />
            </StackPanel>

            <!-- Project name selector -->
            <StackPanel Grid.Row="1" >
                <Label Content="Enter your project name:" Foreground="White" />
                <TextBox x:Name="projectNameTextBox" 
                         Text="{Binding ProjectName, UpdateSourceTrigger=LostFocus}" 
                         FontSize="{StaticResource FontSizeSmall}" />
            </StackPanel>

            <!-- Project output folder selector -->
            <StackPanel Grid.Row="2">
                <Label Content="Project folder:" Foreground="White" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="OutputFolderTextBox" 
                             Grid.Column="0"
                             FontSize="{StaticResource FontSizeSmall}" 
                             Text="{Binding OutputFolder, UpdateSourceTrigger=LostFocus}"/>

                    <Button x:Name="BrowseBtn" Grid.Column="1"
                            Padding="{StaticResource PaddingSizeSmall}"
                            Background="White"
                            Content="Browse…"
                            Margin="0,5,5,5"
                            FontSize="{StaticResource FontSizeSmall}"
                            FontFamily="{StaticResource PoppinsFont}"
                            Cursor="Hand"
                            Command="{Binding BrowseCommand}"/>
                </Grid>
            </StackPanel>

            <!-- Project type selector -->
            <StackPanel Grid.Row="3">
                <Label Content="Project type:" Foreground="White" />
                <UniformGrid Columns="2">

                    <!-- WPF Option -->
                    <RadioButton x:Name="WpfRadio"
                                 IsChecked="{Binding SelectedProjectType, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=WINDOWS_PRESENTATION_FOUNDATION}"
                                 Style="{StaticResource ProjectTypeRadioStyle}"
                                 Tag="M240-320h360v-200H240v200Zm420-120h60v-200H360v60h300v140ZM160-160q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h640q33 0 56.5 23.5T880-720v480q0 33-23.5 56.5T800-160H160Zm0-80h640v-480H160v480Zm0 0v-480 480Z">
                        <StackPanel>
                            <TextBlock Text="WPF"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="Windows Presentation" FontSize="10" Foreground="Gray"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- WinForms Option -->
                    <RadioButton x:Name="WinFormsRadio"
                                 IsChecked="{Binding SelectedProjectType, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=WINDOWS_FORMS}"
                                 Style="{StaticResource ProjectTypeRadioStyle}"
                                 Tag="M160-160q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h640q33 0 56.5 23.5T880-720v480q0 33-23.5 56.5T800-160H160Zm0-80h640v-400H160v400Z">
                        <StackPanel>
                            <TextBlock Text="WinForms"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="Windows Forms" FontSize="10" Foreground="Gray"/>
                        </StackPanel>
                    </RadioButton>
                </UniformGrid>
            </StackPanel>

            <!-- Project Architecture selector -->
            <StackPanel Grid.Row="4">
                <Label Content="Architecture:" Foreground="White" />
                <!-- DAL Card -->
                <CheckBox Style="{StaticResource DalCheckBoxStyle}"
                          IsChecked="True">
                    <StackPanel>
                        <TextBlock Text="Data Access Layer"
                                   FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="Database connection, CRUD operations, stored procedure calls"
                                   Foreground="Gray"
                                   FontSize="10"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </CheckBox>

                <!-- BLL Card -->
                <CheckBox Style="{StaticResource BllCheckBoxStyle}"
                          IsChecked="True">
                    <StackPanel>
                        <TextBlock Text="Business Logic Layer"
                                   FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="Validation, rules, service methods, and business processes"
                                   Foreground="Gray"
                                   FontSize="10"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </CheckBox>
            </StackPanel>

            <!-- List of Tables -->
            <Grid Grid.Row="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Label Content="Tables:" Foreground="White"/>

                <CheckBox Grid.Row="1"
                          Content="Select All"
                          Foreground="White"
                          IsChecked="{Binding AreAllTablesSelected}"
                          IsEnabled="{Binding CanSelectAllTables}"/>

                <ListView Grid.Row="2"
                          ItemsSource="{Binding Tables}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding TableName}"
                                      IsChecked="{Binding IsSelected}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
        
        <!--#endregion-->

        <!--#region Bottom Side-->
        
        <Grid Grid.Row="1" Grid.ColumnSpan="4" Background="{StaticResource PrimaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label x:Name="CurrentDateTimeTextBlock" Grid.Column="0" Foreground="White" FontWeight="Normal" FontSize="14" VerticalAlignment="Center" Margin="5" d:Content="18 May, 2026 - 13:56:20" />

            <Button Click="DisconnectBtn_Click" Grid.Column="1" Style="{StaticResource DangerBtn}" Content="Disconnect" HorizontalAlignment="Right" />
        </Grid>
        
        <!--#endregion-->
        
    </Grid>
</Window>
