<Window x:Class="Code_Generatore.CodeGeneratoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Code_Generatore"
        xmlns:userControl="clr-namespace:Code_Generatore.UserControls"
        mc:Ignorable="d"
        Title="Code generatore" MinHeight="450" Height="450" Width="800" MinWidth="800"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"  />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"  />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!--#region Left Side-->

        <Grid Grid.Column="0" Grid.Row="0" Background="{StaticResource PrimaryBrush}" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" >
                <Label Content="Choose your database:" Foreground="White" />
                <ComboBox x:Name="DatabasesComboBox" 
                          ItemsSource="{Binding DatabasesList}" 
                          SelectedItem="{Binding SelectedDatabase, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Grid.Row="1" >
                <Label Content="Enter your project name:" Foreground="White" />
                <TextBox d:Text="CodeGeneratore" FontSize="{StaticResource FontSizeSmall}" />
            </StackPanel>

            <StackPanel Grid.Row="2">
                <Label Content="Output folder:" Foreground="White" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="OutputFolderTextBox" d:Text="C:/Desktop" FontSize="{StaticResource FontSizeSmall}" Grid.Column="0" />

                    <Button x:Name="BrowseBtn" Grid.Column="1"
                            Style="{StaticResource InputStyle}"
                            Background="White"
                            Content="Browse…"
                            Margin="0,5,5,5"
                            FontSize="{StaticResource FontSizeSmall}"
                            Cursor="Hand"
                            Click="BrowseBtn_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
        
        <!--#endregion-->

        <!-- #region Right Top Side -->
        
        <Border Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2"
                VerticalAlignment="Top"
                Margin="{StaticResource MarginSize}"
                BorderBrush="{StaticResource PrimaryBrush}"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Background="{StaticResource PrimaryBrush}"
                        Padding="{StaticResource PaddingSizeSmall}">
                    
                    <TextBlock Text="General information"
                       Foreground="White"
                       FontFamily="{StaticResource PoppinsFont}"
                       FontSize="{StaticResource FontSizeSmall}"
                       FontWeight="Normal"/>
                </Border>

                <!-- Info Row -->
                <Grid Grid.Row="1" Margin="{StaticResource MarginSize}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Server -->
                    <userControl:InfoItemControl Grid.Column="0" Title="Server Name :" Value="{Binding Session.ServerName}" />

                    <!-- Username -->
                    <userControl:InfoItemControl Grid.Column="1" Title="Username :" Value="{Binding Session.UserName}" />

                    <!-- Status -->
                    <userControl:InfoItemControl Grid.Column="2" Title="Status :" Value="{Binding Session.ConnectionStatus}" />

                    <!-- Database -->
                    <userControl:InfoItemControl Grid.Column="3" Title="Database Name :" Value="{Binding Session.DatabaseName}" />
                </Grid>
            </Grid>
        </Border>
        
        <!-- #endregion -->

        <!--#region Bottom Side-->
        
        <Grid Grid.Row="1" Grid.ColumnSpan="3" Background="{StaticResource PrimaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label x:Name="CurrentDateTimeTextBlock" Grid.Column="0" Foreground="White" FontWeight="Normal" FontSize="14" VerticalAlignment="Center" Margin="5" d:Content="18 May, 2026 - 13:56:20" />

            <Button Click="DisconnectBtn_Click" Grid.Column="1" Style="{StaticResource DangerBtn}" Content="Disconnect" HorizontalAlignment="Right" />
        </Grid>
        
        <!--#endregion-->
        
    </Grid>
</Window>
