<Application x:Class="Code_Generatore.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Code_Generatore"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- #region Fonts -->
        
        <FontFamily x:Key="PoppinsFont">./Fonts/#Poppins</FontFamily>
        
        <!-- #endregion -->
        
        <!-- #region Colors -->
        
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4895EF"/>
        <SolidColorBrush x:Key="DengerBrush" Color="#ff002b"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#5FA3F1"/>
        <SolidColorBrush x:Key="DengerHoverBrush" Color="#ff4d6b"/>
        <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#2F66B0"/>
        <SolidColorBrush x:Key="DengerPressedBrush" Color="#b3001e"/>
        <SolidColorBrush x:Key="PrimaryDisabledBrush" Color="#BDE0FE"/>
        <SolidColorBrush x:Key="DengerDisabledBrush" Color="#ff9aab"/>
        
        <!-- #endregion -->
        
        <!--#region Sizes-->

        <!-- Font sizes -->
        <sys:Double x:Key="FontSizeSmall">12</sys:Double>
        <sys:Double x:Key="FontSizeNormal">14</sys:Double>
        <sys:Double x:Key="FontSizeLarge">16</sys:Double>

        <!-- Control sizes -->
        <sys:Double x:Key="ControlHeight">34</sys:Double>

        <!-- Margin sizes -->
        <Thickness x:Key="MarginSize">5</Thickness>

        <!-- Padding sizes -->
        <Thickness x:Key="PaddingSizeSmall">5</Thickness>
        <Thickness x:Key="PaddingSizeMedium">10</Thickness>

        <!--#endregion-->
        
        <!-- #region Buttons Style -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeLarge}"/>
            <Setter Property="FontWeight" Value="DemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="{StaticResource MarginSize}"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">

                            <ContentPresenter 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="{StaticResource PrimaryHoverBrush}"/>
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="{StaticResource PrimaryPressedBrush}"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="{StaticResource PrimaryDisabledBrush}"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DengerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource DengerBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeLarge}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="{StaticResource MarginSize }"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">

                            <ContentPresenter 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                Property="Background"
                                Value="{StaticResource DengerHoverBrush}"/>
                                <Setter TargetName="border"
                                Property="BorderBrush"
                                Value="{StaticResource DengerHoverBrush}"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                Property="Background"
                                Value="{StaticResource DengerPressedBrush}"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border"
                                Property="Background"
                                Value="{StaticResource DengerDisabledBrush}"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- #endregion -->
        
        <!-- #region Labels Style -->

        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeLarge}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        </Style>
        
        <!-- #endregion -->

        <!-- #region Input Controls Style -->
        
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Padding" Value="{StaticResource PaddingSizeSmall}"/>
            <Setter Property="Margin" Value="{StaticResource MarginSize}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeLarge}"/>
            <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        </Style>
        
        <!--#endregion-->
        
        <!-- #region TextBoxes Style -->

        <Style TargetType="TextBox"
               BasedOn="{StaticResource InputStyle}" />
        
        <!-- #endregion -->
        
        <!-- #region PasswordBoxes Style -->

        <Style TargetType="PasswordBox"
               BasedOn="{StaticResource InputStyle}" >
            <Setter Property="PasswordChar" Value="•" />
        </Style>

        <!-- #endregion -->
        
        <!-- #region Checkboxes Style -->

        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        </Style>
        
        <!-- #endregion -->
        
        <!-- #region TextBlocks Style -->

        <Style x:Key="DescriptionText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource PoppinsFont}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="Gray"/>
        </Style>

        <!-- #endregion -->
        
        <!--#region ComboBox Style-->

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="{StaticResource MarginSize}" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>

                             <!--Border--> 
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}">

                                <Grid>
                                     <!--Selected Content-->
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Margin="10,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left" />

                                    <ToggleButton x:Name="ToggleButton"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  HorizontalAlignment="Right"
                                                  Width="35">
                                        
                                        <Path Data="M 0 0 L 4 4 L 8 0"
                                              Stroke="{StaticResource PrimaryBrush}"
                                              StrokeThickness="2"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                             <!--Popup--> 
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">

                                <Border Background="White"
                                        BorderBrush="{StaticResource PrimaryBrush}"
                                        BorderThickness="1"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Padding="10">

                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>

                                </Border>
                            </Popup>

                        </Grid>

                        <ControlTemplate.Triggers>

                             <!--Hover--> 
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>

                             <!--Focus--> 
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>

                             <!--Open state--> 
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="{StaticResource PaddingSizeMedium}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{StaticResource PrimaryDisabledBrush}"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#E0EFFF"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--#endregion-->
        
    </Application.Resources>
</Application>
