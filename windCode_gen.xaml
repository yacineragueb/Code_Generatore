<Window x:Class="Code_Generatore.windCode_gen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Code_Generatore"
        mc:Ignorable="d"
        Title="Code generator" MinHeight="450" Height="450" Width="800" MinWidth="800"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"  />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"  />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!--#region Left Side-->

        <Grid Grid.Column="0" Grid.Row="0" Background="{StaticResource PrimaryBrush}" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" >
                <Label Content="Choose your database:" Foreground="White" />
                <ComboBox >
                    <ComboBoxItem IsSelected="True" Content="C#"/>
                    <ComboBoxItem Content="WPF"/>
                    <ComboBoxItem Content="SQL Server"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="1" >
                <Label Content="Enter your project name:" Foreground="White" />
                <TextBox />
            </StackPanel>
        </Grid>
        
        <!--#endregion-->

        <!--#region Bottom Side-->
        
        <Grid Grid.Row="1" Grid.ColumnSpan="3" Background="{StaticResource PrimaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label x:Name="CurrentDateTimeTextBlock" Grid.Column="0" Foreground="White" FontWeight="Normal" FontSize="14" VerticalAlignment="Center" Margin="5" d:Content="18 May, 2026 - 13:56:20" />

            <Button Grid.Column="1" Style="{StaticResource DangerBtn}" Content="Disconnect" HorizontalAlignment="Right" />
        </Grid>
        
        <!--#endregion-->
        
    </Grid>
</Window>
